---
/**
 * SiteNav.astro
 *
 * Navigation principale du Design System.
 * Structure en sections : Foundations, Components.
 * Les composants sont auto-générés depuis le CEM + MDX.
 */
import { getCollection } from 'astro:content';
import { getSlug } from '../utils/tag-name.ts';
import manifest from '@cem';
import { version } from '../../../../packages/core/package.json';
import { type CemDeclaration, getCustomElements } from '../utils/cem-types.ts';

interface Props {
    currentPath?: string;
}

const { currentPath = '' } = Astro.props;

// ─── Sections statiques ──────────────────────────────────────────────────────

interface NavLink {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

const foundationsLinks: NavLink[] = [
    { href: '/foundations/tokens', label: 'Design Tokens', ariaCurrent: undefined },
].map((link) => ({
    ...link,
    ariaCurrent: currentPath === link.href ? ('page' as const) : undefined,
}));

// ─── Composants (dynamique depuis CEM + MDX) ────────────────────────────────

interface NavChild {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

interface NavItem {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
    children:    NavChild[];
}

const allComponents: CemDeclaration[] = getCustomElements(manifest);

const allMdx   = await getCollection('components');
const mdxByTag = Object.fromEntries(allMdx.map((e) => [e.data.tagName, e]));

const childrenByParent = allComponents.reduce<Record<string, CemDeclaration[]>>(
    (acc, c) => {
        const parent = c['x-parent'];
        if (!parent) return acc;
        (acc[parent] ??= []).push(c);
        return acc;
    },
    {}
);

const componentItems: NavItem[] = allComponents
    .filter((c) => !c['x-parent'])
    .map((c) => {
        const href     = '/components/' + getSlug(c.tagName!);
        const rawChildren = childrenByParent[c.tagName!] ?? [];

        return {
            href,
            label:       mdxByTag[c.tagName!]?.data.title ?? c.name,
            ariaCurrent: currentPath === href ? ('page' as const) : undefined,
            children:    rawChildren.map((child) => {
                const childHref = '/components/' + getSlug(child.tagName!);
                return {
                    href:        childHref,
                    label:       mdxByTag[child.tagName!]?.data.title ?? child.name,
                    ariaCurrent: currentPath === childHref ? ('page' as const) : undefined,
                };
            }),
        };
    });
---

<nav aria-label="Design System">
    <div class="nav-container">
        <div class="nav-section">
            <h2>Fondations</h2>
            <ul class="nav-list">
                {foundationsLinks.map((link) => (
                    <li>
                        <a href={link.href} aria-current={link.ariaCurrent}>{link.label}</a>
                    </li>
                ))}
            </ul>
        </div>

        <div class="nav-section">
            <h2>Composants</h2>
            <ul class="nav-list">
                {componentItems.map((item) => (
                    <li class={item.children.length ? 'has-children' : ''}>
                        <a href={item.href} aria-current={item.ariaCurrent}>{item.label}</a>
                        {item.children.length > 0 && (
                            <ul class="nav-children">
                                {item.children.map((child) => (
                                    <li>
                                        <a href={child.href} aria-current={child.ariaCurrent}>
                                            {child.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        )}
                    </li>
                ))}
            </ul>
        </div>
    </div>

    <footer class="nav-footer">
        <h5 class="nav-brand">mARIAnne</h5>
        <p class="nav-footer-version">Version {version}</p>
        <div class="nav-footer-meta">
            {/* <div class="nav-footer-social">
                Emplacement réseaux sociaux — ajouter des <a> ici quand disponibles
            </div> */}
            <a
                href="https://github.com/jonTravens/mARIAnne/"
                target="_blank"
                rel="noopener noreferrer"
                class="nav-footer-link"
                aria-label="Code source sur GitHub"
            >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.79 23.4c.6.1.82-.26.82-.57v-2.2c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.08-.74.08-.73.08-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.48 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57A12 12 0 0 0 12 .3"/></svg>
                GitHub
            </a>
        </div>
    </footer>
</nav>

<style>
    nav {
        display:         flex;
        flex-direction:  column;
        justify-content: space-between;
        flex-grow:       1;
        padding:         1.25rem 0.75rem;
        border-right:    1px solid var(--doc-nav-border, #e2e4e9);
        background:      var(--doc-nav-bg, #f8f9fb);
        position:        sticky;
        top:             0;
        height:          100%;
        overflow-y:      auto;
        scrollbar-width: thin;
        scrollbar-color: #d1d5db transparent;
    }

    nav::-webkit-scrollbar       { width: 4px; }
    nav::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }

    /* ── Marque (masquée sur desktop, le header a déjà le logo) ── */

    .nav-brand {
        font-weight:     500;
        font-size:       .8rem;
        letter-spacing:  -0.02em;
        color:           var(--doc-text, #1a1d26);
        text-decoration: none;
        margin: 0;
        flex-shrink:     0;
    }

    .brand-accent {
        color: var(--mr-color-primary-500, #2563eb);
    }

    /* ── Sections ────────────────────────────────────────────── */

    .nav-container {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .nav-section {
        margin-bottom: 1.25rem;
    }

    .nav-section h2 {
        font-size:      0.65rem;
        font-weight:    700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color:          var(--doc-text-muted, #8b8fa7);
        padding:        0 0.75rem;
        margin:         0 0 0.4rem;
    }

    /* ── Listes ──────────────────────────────────────────────── */

    .nav-list,
    .nav-children {
        list-style: none;
        margin:     0;
        padding:    0;
    }

    .nav-list a {
        display:         block;
        padding:         0.4rem 0.75rem;
        color:           var(--doc-text-muted, #4a4e5a);
        text-decoration: none;
        border-radius:   0.375rem;
        font-size:       0.85rem;
        font-weight:     450;
        transition:      background 0.12s, color 0.12s;
        border-left:     5px solid transparent;
    }

    .nav-list a:hover {
        background: color-mix(in srgb, var(--doc-nav-border, #e2e4e9) 60%, transparent);
        color:      var(--doc-text, #1a1d26);
    }

    .nav-list a[aria-current="page"] {
        background:                color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 10%, transparent);
        color:                     var(--mr-color-primary-500, #2563eb);
        border-top-left-radius:    0;
        border-bottom-left-radius: 0;
        font-weight:               600;
        border-left-color:         var(--mr-color-primary-500, #2563eb);
    }

    /* ── Enfants (sous-composants) ───────────────────────────── */

    .nav-children {
        margin:       0.15rem 0 0.25rem 1.2rem;
        padding-left: 0;
        border-left:  1.5px solid var(--doc-border, #dfe1e7);
    }

    .nav-children a {
        font-size: 0.8rem;
        padding:   0.3rem 0.6rem;
    }

    /* ── Footer nav (theme toggle dans le drawer mobile uniquement) ── */

    /* ── Footer nav ──────────────────────────────────────────── */

    .nav-footer {
        display: flex;
        flex-direction: column;
        row-gap: .5rem;
        padding:     1rem 0.75rem 0;
        border-top:  1px solid var(--doc-border, #e5e7eb);
        flex-shrink: 0;
    }

    .nav-footer-social {
        /* Emplacement réseaux sociaux : ajouter display:flex + gap quand peuplé */
        min-height: 0;
    }

    .nav-footer-meta {
        display:     flex;
        align-items: center;
    }

    .nav-footer-link {
        display:         flex;
        align-items:     center;
        gap:             0.3rem;
        color:           var(--doc-text-muted, #6b7280);
        text-decoration: none;
        font-size:       0.8rem;
        transition:      color 0.12s;
    }

    .nav-footer-link:hover { color: var(--doc-text, #111827); }

    .nav-footer-version {
        font-size:   0.7rem;
        margin: 0;
        font-family: 'Fira Code', 'Cascadia Code', monospace;
        color:       var(--doc-text-muted, #9ca3af);
    }
</style>
