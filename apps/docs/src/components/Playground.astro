---
/**
 * Playground.astro
 *
 * Affiche les variantes d'un composant empilées verticalement (style Webawesome),
 * un playground interactif avec contrôles générés depuis le CEM,
 * et la référence API complète via ComponentApi.
 *
 * Tout le rendu des composants est server-side (Fragment set:html).
 * Le JS client gère uniquement la copie du code et les contrôles du playground.
 */

import ComponentApi from './ComponentApi.astro';

interface Variant {
    name:         string;
    label?:       string;
    description?: string;
    html:         string;
}

interface CemControl {
    attribute:    string;
    description?: string;
    controlType:  'select' | 'checkbox' | 'text' | 'number';
    options:      string[];
    default?:     string;
    addDefault?:  boolean;
}

interface CemDeclaration {
    kind:           string;
    customElement?: boolean;
    tagName?:       string;
    name:           string;
    summary?:       string;
    description?:   string;
    members?:       unknown[];
    attributes?:    unknown[];
    events?:        unknown[];
    cssParts?:      unknown[];
    cssProperties?: unknown[];
    slots?:         unknown[];
}

interface Props {
    variants:            Variant[];
    tagName:             string;
    displayMode:         'demo' | 'docs';
    parentTag?:          string;
    playgroundHtml:      string;
    controls:            CemControl[];
    component:           CemDeclaration;
}

const {
    variants,
    tagName,
    displayMode = 'demo',
    parentTag,
    playgroundHtml,
    controls,
    component,
} = Astro.props;

const showPlayground = displayMode === 'demo';
---

{/* ── Exemples (variantes) ── */}
{variants.length > 0 && (
    <section class="examples-section" id="exemples">
        <h2>Exemples</h2>
        {variants.map((variant) => (
            <section class="variant" id={`exemple-${variant.name}`}>
                <h3>{variant.label ?? variant.name}</h3>
                {variant.description && (
                    <p class="variant-description">{variant.description}</p>
                )}
                <div class="preview">
                    <Fragment set:html={variant.html} />
                </div>
                <div class="code-block">
                    <button class="copy-btn" data-copy aria-label="Copier le code">
                        Copier
                    </button>
                    <pre><code>{variant.html.trim()}</code></pre>
                </div>
            </section>
        ))}
    </section>
)}

{/* ── Encart parent pour les sous-composants ── */}
{parentTag && (
    <div class="parent-notice">
        <span class="parent-notice-icon">&#8593;</span>
        Ce composant est un sous-composant de
        <a href={`/components/${parentTag.replace(/^mr-/, '')}`}>
            <code>&lt;{parentTag}&gt;</code>
        </a>
    </div>
)}

{/* ── Playground interactif ── */}
{showPlayground && (
    <section class="playground-section" id="playground" data-playground data-tag-name={tagName}>
        <h2>Playground</h2>
        <div class="preview" data-playground-preview>
            <Fragment set:html={playgroundHtml} />
        </div>
        <div class="playground-code-block">
            <button class="copy-btn" data-copy-playground aria-label="Copier le code">Copier</button>
            <pre><code data-playground-code>{playgroundHtml.trim()}</code></pre>
        </div>

        {controls.length > 0 && (
            <div class="controls-panel">
                {controls.map((ctrl) => (
                    <label class="control-row">
                        <span class="control-label">{ctrl.attribute}</span>
                        {ctrl.controlType === 'select' && (
                            <select
                                data-attr={ctrl.attribute}
                                data-playground-ctrl
                                data-default={ctrl.default ?? ''}
                            >
                                {ctrl.addDefault && (
                                    <option value="">Par défaut</option>
                                )}
                                {ctrl.options.map((opt) => (
                                    <option value={opt}>{opt}</option>
                                ))}
                            </select>
                        )}
                        {ctrl.controlType === 'checkbox' && (
                            <input
                                type="checkbox"
                                data-attr={ctrl.attribute}
                                data-playground-ctrl
                            />
                        )}
                        {ctrl.controlType === 'text' && (
                            <input
                                type="text"
                                data-attr={ctrl.attribute}
                                data-playground-ctrl
                                data-default={ctrl.default ?? ''}
                                placeholder={ctrl.default ?? ''}
                            />
                        )}
                        {ctrl.controlType === 'number' && (
                            <input
                                type="number"
                                data-attr={ctrl.attribute}
                                data-playground-ctrl
                                data-default={ctrl.default ?? ''}
                                placeholder={ctrl.default ?? ''}
                            />
                        )}
                    </label>
                ))}
            </div>
        )}
    </section>
)}

{/* ── Référence API ── */}
<section id="reference-api">
    <h2>Référence API</h2>
    <ComponentApi component={component} />
</section>

<script src="/js/playground.js" is:inline></script>

<style>
    /* ── Sections communes ─────────────────────────────── */

    .examples-section,
    .playground-section,
    #reference-api {
        margin: 2.5rem 0;
    }

    h2 {
        font-size:      1.25rem;
        font-weight:    700;
        border-bottom:  2px solid #e5e7eb;
        padding-bottom: 0.5rem;
        margin-bottom:  1.5rem;
        color:          #111827;
    }

    /* ── Variantes ─────────────────────────────────────── */

    .variant {
        margin-bottom: 2.5rem;
    }

    h3 {
        font-size:     1rem;
        font-weight:   600;
        color:         #374151;
        margin-bottom: 0.5rem;
    }

    .variant-description {
        font-size:     0.875rem;
        color:         #6b7280;
        font-style:    italic;
        margin-bottom: 0.75rem;
    }

    /* ── Preview ─────────────────────────────────────── */

    .preview {
        display:       flex;
        flex-wrap:     wrap;
        gap:           0.75rem;
        align-items:   center;
        padding:       2rem;
        background:    #fff;
        border:        1px solid #e5e7eb;
        border-radius: 0.5rem 0.5rem 0 0;
    }

    /* ── Code block ─────────────────────────────────── */

    .code-block {
        position:      relative;
        background:    #1e1e2e;
        border:        1px solid #e5e7eb;
        border-top:    none;
        border-radius: 0 0 0.5rem 0.5rem;
    }

    .copy-btn {
        position:      absolute;
        top:           0.5rem;
        right:         0.5rem;
        padding:       0.25rem 0.6rem;
        background:    #374151;
        color:         #d1d5db;
        border:        none;
        border-radius: 0.25rem;
        font-size:     0.75rem;
        cursor:        pointer;
        transition:    background 0.15s;
        z-index:       1;
    }

    .copy-btn:hover  { background: #4b5563; }
    .copy-btn.copied { background: #059669; color: #fff; }

    pre {
        margin:      0;
        padding:     1rem 1rem 1rem 1.25rem;
        overflow-x:  auto;
        font-family: 'Fira Code', 'Cascadia Code', monospace;
        font-size:   0.8rem;
        line-height: 1.6;
        color:       #cdd6f4;
    }

    pre code {
        background: transparent;
        padding:    0;
        font-size:  inherit;
    }

    /* ── Playground contrôles ────────────────────────── */

    .playground-section .preview {
        border-radius: 0.5rem 0.5rem 0 0;
        border-bottom: none;
        margin-bottom: 0;
    }

    .playground-code-block {
        position:      relative;
        background:    #1e1e2e;
        border:        1px solid #e5e7eb;
        border-top:    none;
    }

    .controls-panel {
        border:        1px solid #e5e7eb;
        border-top:    none;
        border-radius: 0 0 0.5rem 0.5rem;
        padding:       1rem 1.5rem;
        background:    #f9fafb;
        display:       flex;
        flex-wrap:     wrap;
        gap:           1rem 2rem;
        align-items:   start;
    }

    .control-row {
        display:     flex;
        flex-direction: column;
        gap:         0.25rem;
        min-width:   140px;
    }

    .control-label {
        font-size:   0.75rem;
        font-weight: 600;
        color:       #6b7280;
        font-family: 'Fira Code', 'Cascadia Code', monospace;
    }

    .control-row select,
    .control-row input[type="text"],
    .control-row input[type="number"] {
        padding:       0.3rem 0.5rem;
        border:        1px solid #d1d5db;
        border-radius: 0.25rem;
        font-size:     0.875rem;
        background:    #fff;
        color:         #111827;
        width:         100%;
    }

    .control-row input[type="checkbox"] {
        width:  1.1rem;
        height: 1.1rem;
        cursor: pointer;
        margin-top: 0.2rem;
    }

    /* ── Encart parent ───────────────────────────────── */

    .parent-notice {
        display:       flex;
        align-items:   center;
        gap:           0.5rem;
        padding:       0.75rem 1rem;
        background:    color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 8%, transparent);
        border:        1px solid color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 20%, transparent);
        border-radius: 0.5rem;
        font-size:     0.875rem;
        color:         #374151;
        margin:        1rem 0;
    }

    .parent-notice-icon {
        font-size:   1.1rem;
        font-weight: 700;
        color:       var(--mr-color-primary-500, #2563eb);
    }

    .parent-notice a {
        color:           var(--mr-color-primary-500, #2563eb);
        text-decoration: none;
        font-weight:     600;
    }

    .parent-notice a:hover {
        text-decoration: underline;
    }
</style>
