---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Playground from '../../components/Playground.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import manifest from '@cem';
import { getSlug } from '../../utils/tag-name.ts';
import { type CemDeclaration, getCustomElements, buildControls } from '../../utils/cem-types.ts';

type MdxEntry = Awaited<ReturnType<typeof getCollection<'components'>>>[number];

// ─── Routes statiques ─────────────────────────────────────────────────────────

export async function getStaticPaths() {
    const components: CemDeclaration[] = getCustomElements(manifest);

    const mdxEntries = await getCollection('components');
    const mdxByTag   = Object.fromEntries(mdxEntries.map((e) => [e.data.tagName, e]));

    return components.map((component) => ({
        params: { slug: getSlug(component.tagName!) },
        props:  { component, mdx: mdxByTag[component.tagName!] ?? null },
    }));
}

// ─── Props de la page ─────────────────────────────────────────────────────────

const { component, mdx } = Astro.props as {
    component: CemDeclaration;
    mdx: MdxEntry | null;
};

const { Content } = mdx ? await mdx.render() : { Content: null };

const variants    = mdx?.data.variants ?? [];
const pageTitle   = mdx?.data.title ?? component.name;
const pageDesc    = mdx?.data.description ?? component.summary;
const displayMode = component['x-display'] ?? 'demo';
const parentTag   = component['x-parent'];

// ─── HTML initial du playground ───────────────────────────────────────────────

const playgroundVariantName = mdx?.data.playgroundTemplate;
const playgroundVariant = playgroundVariantName
    ? variants.find((v: { name: string }) => v.name === playgroundVariantName)
    : variants[0];
const playgroundHtml = playgroundVariant?.html ?? '';

// ─── Contrôles du playground ──────────────────────────────────────────────────

const controls = buildControls(component.members ?? []);

// ─── TOC ──────────────────────────────────────────────────────────────────────

const tocEntries = [
    ...(variants.length > 0
        ? [
            { id: 'exemples', label: 'Exemples', level: 1 as const },
            ...variants.map((v: { name: string; label?: string }) => ({
                id:    `exemple-${v.name}`,
                label: v.label ?? v.name,
                level: 2 as const,
            })),
          ]
        : []),
    ...(displayMode === 'demo'
        ? [{ id: 'playground', label: 'Playground', level: 1 as const }]
        : []),
    { id: 'reference-api', label: 'Référence API', level: 1 as const },
];
---

<Layout
    title={pageTitle}
    currentPath={'/components/' + getSlug(component.tagName!)}
    showToc={true}
>
    {/* TOC mobile : visible uniquement sur mobile, injectée dans le flux principal */}
    <div class="toc-mobile-inline">
        <TableOfContents entries={tocEntries} mobileOnly={true} />
    </div>

    <h3>{pageTitle}</h3>
    <code>&lt;{component.tagName}&gt;</code>
    {pageDesc && <p class="summary">{pageDesc}</p>}


    <Playground
        variants={variants}
        tagName={component.tagName!}
        displayMode={displayMode}
        parentTag={parentTag}
        playgroundHtml={playgroundHtml}
        controls={controls}
        component={component}
    />

    {Content && (
        <section class="narrative">
            <Content />
        </section>
    )}

    <TableOfContents entries={tocEntries} slot="toc" />
</Layout>

<style>
    /* La version desktop de la TOC inline est masquée — seul le <details> mobile s'affiche */
    .toc-mobile-inline { display: none; }
    @media (max-width: 768px) {
        .toc-mobile-inline { display: block; }
    }

    h3 {
        font-size: 2rem;
        color:     var(--doc-text, #111827);
        margin:    0;
    }

    h3 + code {
        font-size:  1rem;
        display:    block;
        background: none;
        padding:    0;
        color:      var(--doc-text-muted, #6b7280);
    }

    .summary {
        font-size: 1.05rem;
        color:     var(--doc-text-muted, #4b5563);
        margin:    0;
    }

    .narrative {
        margin:      1.5rem 0;
        color:       var(--doc-text, #374151);
        line-height: 1.7;
    }

    .narrative :global(p)    { margin-bottom: 0.75rem; }

    .narrative :global(code) {
        font-size:     0.85em;
        background:    var(--doc-nav-bg, #f3f4f6);
        color:         var(--doc-text, #111827);
        padding:       0.1em 0.35em;
        border-radius: 0.25em;
    }
</style>
