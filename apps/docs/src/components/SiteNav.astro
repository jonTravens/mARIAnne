---
/**
 * SiteNav.astro
 *
 * Navigation principale du Design System.
 * Structure en sections : Foundations, Components.
 * Les composants sont auto-générés depuis le CEM + MDX.
 */
import { getCollection } from 'astro:content';
import { getSlug } from '../utils/tag-name.ts';
import manifest from '@cem';

interface CemDeclaration {
    kind:           string;
    customElement?: boolean;
    tagName?:       string;
    name:           string;
    'x-parent'?:    string;
    'x-display'?:   'demo' | 'docs';
}

interface Props {
    currentPath?: string;
}

const { currentPath = '' } = Astro.props;

// ─── Sections statiques ──────────────────────────────────────────────────────

interface NavLink {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

const foundationsLinks: NavLink[] = [
    { href: '/foundations/tokens', label: 'Design Tokens', ariaCurrent: undefined },
].map((link) => ({
    ...link,
    ariaCurrent: currentPath === link.href ? ('page' as const) : undefined,
}));

// ─── Composants (dynamique depuis CEM + MDX) ────────────────────────────────

interface NavChild {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
}

interface NavItem {
    href:        string;
    label:       string;
    ariaCurrent: 'page' | undefined;
    children:    NavChild[];
}

const allComponents: CemDeclaration[] = manifest.modules
    .flatMap((m: { declarations?: CemDeclaration[] }) => m.declarations ?? [])
    .filter((d: CemDeclaration) => d.kind === 'class' && d.customElement === true);

const allMdx   = await getCollection('components');
const mdxByTag = Object.fromEntries(allMdx.map((e) => [e.data.tagName, e]));

const childrenByParent = allComponents.reduce<Record<string, CemDeclaration[]>>(
    (acc, c) => {
        const parent = c['x-parent'];
        if (!parent) return acc;
        (acc[parent] ??= []).push(c);
        return acc;
    },
    {}
);

const componentItems: NavItem[] = allComponents
    .filter((c) => !c['x-parent'])
    .map((c) => {
        const href     = '/components/' + getSlug(c.tagName!);
        const rawChildren = childrenByParent[c.tagName!] ?? [];

        return {
            href,
            label:       mdxByTag[c.tagName!]?.data.title ?? c.name,
            ariaCurrent: currentPath === href ? ('page' as const) : undefined,
            children:    rawChildren.map((child) => {
                const childHref = '/components/' + getSlug(child.tagName!);
                return {
                    href:        childHref,
                    label:       mdxByTag[child.tagName!]?.data.title ?? child.name,
                    ariaCurrent: currentPath === childHref ? ('page' as const) : undefined,
                };
            }),
        };
    });
---

<nav aria-label="Design System">
    <a href="/" class="nav-brand">
        m<span class="brand-accent">ARIA</span>nne
    </a>

    <div class="nav-section">
        <h2>Fondations</h2>
        <ul class="nav-list">
            {foundationsLinks.map((link) => (
                <li>
                    <a href={link.href} aria-current={link.ariaCurrent}>{link.label}</a>
                </li>
            ))}
        </ul>
    </div>

    <div class="nav-section">
        <h2>Composants</h2>
        <ul class="nav-list">
            {componentItems.map((item) => (
                <li class={item.children.length ? 'has-children' : ''}>
                    <a href={item.href} aria-current={item.ariaCurrent}>{item.label}</a>
                    {item.children.length > 0 && (
                        <ul class="nav-children">
                            {item.children.map((child) => (
                                <li>
                                    <a href={child.href} aria-current={child.ariaCurrent}>
                                        {child.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    )}
                </li>
            ))}
        </ul>
    </div>
</nav>

<style>
    nav {
        padding:      1.25rem 0.75rem;
        border-right: 1px solid #e2e4e9;
        background:   #f8f9fb;
        position:     sticky;
        top:          0;
        height:       100vh;
        overflow-y:   auto;
        scrollbar-width: thin;
        scrollbar-color: #d1d5db transparent;
    }

    nav::-webkit-scrollbar {
        width: 4px;
    }

    nav::-webkit-scrollbar-thumb {
        background:    #d1d5db;
        border-radius: 4px;
    }

    /* ── Marque ──────────────────────────────────────────────── */

    .nav-brand {
        display:         block;
        font-weight:     800;
        font-size:       2rem;
        letter-spacing:  -0.02em;
        color:           #1a1d26;
        text-decoration: none;
        padding:         0.5rem 0.75rem 1.25rem;
    }

    .brand-accent {
        color: var(--mr-color-primary-500, #2563eb);
        /* font-weight: 700; */
    }

    /* ── Sections ────────────────────────────────────────────── */

    .nav-section {
        margin-bottom: 1.25rem;
    }

    .nav-section h2 {
        font-size:      0.65rem;
        font-weight:    700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color:          #8b8fa7;
        padding:        0 0.75rem;
        margin:         0 0 0.4rem;
    }

    /* ── Listes ──────────────────────────────────────────────── */

    .nav-list,
    .nav-children {
        list-style: none;
        margin:     0;
        padding:    0;
    }

    .nav-list a {
        display:         block;
        padding:         0.4rem 0.75rem;
        color:           #4a4e5a;
        text-decoration: none;
        border-radius:   0.375rem;
        font-size:       0.85rem;
        font-weight:     450;
        transition:      background 0.12s, color 0.12s;
        border-left:     5px solid transparent;
    }

    .nav-list a:hover {
        background: #eef0f4;
        color:      #1a1d26;
    }

    .nav-list a[aria-current="page"] {
        background:   color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 10%, transparent);
        color:        var(--mr-color-primary-500, #2563eb);
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
        font-weight:  600;
        border-left-color: var(--mr-color-primary-500, #2563eb);
    }

    /* ── Enfants (sous-composants) ───────────────────────────── */

    .nav-children {
        margin:       0.15rem 0 0.25rem 1.2rem;
        padding-left: 0rem;
        border-left:  1.5px solid #dfe1e7;
    }

    .nav-children a {
        font-size: 0.8rem;
        padding:   0.3rem 0.6rem;
    }
</style>
