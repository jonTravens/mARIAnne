---
/**
 * TableOfContents.astro
 *
 * Table des matières flottante (sticky) affichée à droite du contenu principal.
 * Les entrées de niveau 2 sont indentées par rapport aux entrées de niveau 1.
 * Un IntersectionObserver surligne l'entrée correspondant à la section visible.
 */

interface TocEntry {
    id:    string;
    label: string;
    level: 1 | 2;
}

interface Props {
    entries: TocEntry[];
}

const { entries } = Astro.props;
---

<nav class="toc" aria-label="Sur cette page">
    <p class="toc-title">Sur cette page</p>
    <ul>
        {entries.map((entry) => (
            <li class={`toc-item level-${entry.level}`}>
                <a href={`#${entry.id}`} class="toc-link">{entry.label}</a>
            </li>
        ))}
    </ul>
</nav>

<script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length > 0) {
        const ids = Array.from(links).map((l) => l.getAttribute('href')!.slice(1));
        const headings = ids
            .map((id) => document.getElementById(id))
            .filter(Boolean) as HTMLElement[];

        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        links.forEach((l) => l.classList.remove('active'));
                        const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
                        active?.classList.add('active');
                    }
                }
            },
            { rootMargin: '0px 0px -70% 0px', threshold: 0 },
        );

        headings.forEach((h) => observer.observe(h));
    }
</script>

<style>
    .toc {
        position:   sticky;
        top:        2rem;
        font-size:  0.8rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        padding:    0 0.5rem;
    }

    .toc-title {
        font-size:      0.7rem;
        font-weight:    700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color:          #9ca3af;
        margin:         0 0 0.5rem;
    }

    ul {
        list-style: none;
        margin:     0;
        padding:    0;
    }

    .toc-item {
        margin: 0;
    }

    .toc-item.level-2 {
        padding-left: 0.75rem;
    }

    .toc-link {
        display:         block;
        padding:         0.25rem 0.5rem;
        color:           #6b7280;
        text-decoration: none;
        border-radius:   0.25rem;
        line-height:     1.4;
        transition:      color 0.1s, background 0.1s;
    }

    .toc-link:hover {
        color:      #111827;
        background: #f3f4f6;
    }

    .toc-link.active {
        color:       var(--mr-color-primary-500, #2563eb);
        font-weight: 500;
        background:  color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 8%, transparent);
    }
</style>
