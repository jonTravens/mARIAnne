---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const tocEntries = [
    { id: 'import',           label: 'Import des composants', level: 1 as const },
    { id: 'personnalisation', label: 'Personnalisation CSS',  level: 1 as const },
    { id: 'tokens',           label: 'Design Tokens',         level: 1 as const },
];

const codeImportGlobal = `import '@marianne/core';
import '@marianne/core/themes/default.css';`;

const codeImportIndividuel = `import '@marianne/core/dist/components/button/button.js';
import '@marianne/core/dist/components/alert/alert.js';
import '@marianne/core/themes/default.css';`;

const codeHtml = `<mr-button variant="filled">Valider</mr-button>

<mr-alert variant="success">
    Votre message a bien été envoyé.
</mr-alert>

<mr-spinner></mr-spinner>`;

const codeCustomProps = `/* Personnaliser mr-button */
mr-button {
    --mr-button-bg:            #7c3aed;
    --mr-button-border-radius: 2rem;
}

/* Cibler une variante spécifique */
mr-button[variant="outlined"] {
    --mr-button-border-color: #7c3aed;
    --mr-button-color:        #7c3aed;
}`;

const codeTokens = `:root {
    --mr-color-primary-500: #7c3aed; /* remplace le bleu par du violet */
    --mr-border-radius-md:  0.75rem;
}`;
---

<Layout
    title="Utilisation"
    currentPath="/getting-started/utilisation"
    showToc={true}
>
    <h2>Utilisation</h2>

    <div class="page-content">
    <section id="import">
        <h3>Import des composants</h3>
        <p>
            Une fois <a href="/getting-started/installation">installée</a>, la bibliothèque s'utilise
            directement en HTML. Les composants sont des Custom Elements natifs — aucun framework requis.
        </p>

        <h4>Import global (tous les composants)</h4>
        <pre><code class="language-typescript" set:text={codeImportGlobal} /></pre>

        <h4>Import individuel <span class="badge-subtle">Tree-shaking</span></h4>
        <p>Pour inclure uniquement les composants effectivement utilisés :</p>
        <pre><code class="language-typescript" set:text={codeImportIndividuel} /></pre>

        <h4>Dans votre HTML</h4>
        <pre><code class="language-html" set:text={codeHtml} /></pre>
    </section>

    <section id="personnalisation">
        <h3>Personnalisation CSS</h3>
        <p>
            Chaque composant expose des <strong>CSS Custom Properties</strong> pour adapter
            l'apparence sans surcharger les styles internes.
        </p>
        <pre><code class="language-css" set:text={codeCustomProps} /></pre>
        <p>
            Les propriétés disponibles par composant sont listées dans la section
            <strong>Référence API</strong> de chaque page de composant.
        </p>
    </section>

    <section id="tokens">
        <h3>Design Tokens</h3>
        <p>
            Les valeurs par défaut (couleurs, espacements, typographie…) viennent du fichier de thème
            <code>themes/default.css</code>. Vous pouvez les surcharger globalement :
        </p>
        <pre><code class="language-css" set:text={codeTokens} /></pre>
        <p>
            Consultez la page <a href="/foundations/tokens">Design Tokens</a> pour la liste complète
            des variables disponibles.
        </p>
    </section>
    </div>

    <TableOfContents entries={tocEntries} slot="toc" />
</Layout>

<style>
    @import '../../styles/doc-prose.css';
</style>
