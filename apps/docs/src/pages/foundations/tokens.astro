---
/**
 * tokens.astro
 *
 * Page auto-générée depuis le fichier de thème default.css.
 * Aucune duplication manuelle : ajouter un token dans le CSS → apparaît ici.
 */
import Layout from '../../layouts/Layout.astro';
import { parseTokens, isColor } from '../../utils/parse-tokens.ts';
import { readFileSync } from 'fs';
import { resolve } from 'path';

// process.cwd() est stable entre dev et build (racine du workspace docs)
const themePath = resolve(process.cwd(), '../../packages/core/src/styles/themes/default.css');
const css = readFileSync(themePath, 'utf-8');

const categories = parseTokens(css);
---

<Layout title="Design Tokens" currentPath="/foundations/tokens">

    <h2 class="page-title">Design Tokens</h2>
    <p class="intro">
        Tokens extraits automatiquement du thème <code>default.css</code>.
        Modifiez le fichier de thème, ces valeurs se mettent à jour à la compilation.
    </p>

    {categories.map((category) => (
        <section>
            <h3>{category.label}</h3>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Token</th>
                            <th>Valeur</th>
                        </tr>
                    </thead>
                    <tbody>
                        {category.tokens.map((token) => (
                            <tr>
                                <td><code>{token.name}</code></td>
                                <td>
                                    {isColor(token.value) && (
                                        <span
                                            class="swatch"
                                            style={`background: ${token.value}`}
                                            title={token.value}
                                        />
                                    )}
                                    <code class="value">{token.value}</code>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    ))}

</Layout>

<style>
    @import '../../styles/doc-table.css';

    .intro {
        font-size:     0.95rem;
        color:         var(--doc-text-muted, #4b5563);
        margin-bottom: 2rem;
    }

    section {
        margin-bottom: 2.5rem;
    }

    .page-title {
        color:       var(--doc-text, #111827);
        font-size: 2em;
        margin-bottom: 0;

        + p, + section {
            margin-top: 1.5rem;
        }
    }

    h3 {
        font-size:      1.1rem;
        font-weight:    600;
        border-bottom:  1px solid var(--doc-border, #e5e7eb);
        padding-bottom: 0.5rem;
        margin-bottom:  1rem;
        color:          var(--doc-text, #111827);
    }

    /* Tokens page : swatch un peu plus grande que dans ComponentApi */
    .swatch {
        width:  1.5rem;
        height: 1.5rem;
    }

    .value {
        color: var(--doc-text-muted, #6b7280);
    }

    .ref {
        font-size:  0.75rem;
        color:      var(--doc-text-muted, #9ca3af);
        font-style: italic;
    }
</style>
