---
/**
 * ComponentApi.astro
 *
 * Affiche l'API complète d'un composant à partir des données du Custom Elements Manifest.
 * Toutes les sections (attributs, events, CSS parts, CSS props, slots) sont auto-générées.
 * Ajouter une annotation JSDoc dans le composant TS → apparaît ici automatiquement.
 */
import { type CemDeclaration } from '../utils/cem-types.ts';

interface Props {
    component: CemDeclaration;
}

const { component } = Astro.props;

function isColorValue(value: string | undefined): boolean {
    if (!value) return false;
    return /^#[0-9a-fA-F]{3,8}$/.test(value) || /^rgba?\(/.test(value);
}
---

<div class="component-api">

    {/* ── Attributs & Propriétés ── */}
    {component.attributes && component.attributes.length > 0 && (
        <section>
            <h4 id="api-attributs" class="doc-section-title">Attributs &amp; Propriétés</h4>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Attribut</th>
                            <th>Type</th>
                            <th>Défaut</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {component.attributes.map((attr) => (
                            <tr>
                                <td><code>{attr.name}</code></td>
                                <td><code>{attr.type?.text ?? '—'}</code></td>
                                <td><code>{attr.default ?? '—'}</code></td>
                                <td>{attr.description ?? ''}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    )}

    {/* ── Événements ── */}
    {component.events && component.events.length > 0 && (
        <section>
            <h4 id="api-evenements" class="doc-section-title">Événements</h4>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Événement</th>
                            <th>Type</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {component.events.map((event) => (
                            <tr>
                                <td><code>{event.name}</code></td>
                                <td><code>{event.type?.text ?? 'CustomEvent'}</code></td>
                                <td>{event.description ?? ''}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    )}

    {/* ── CSS Parts ── */}
    {component.cssParts && component.cssParts.length > 0 && (
        <section>
            <h4 id="api-css-parts" class="doc-section-title">CSS Parts</h4>
            <p class="hint">
                Utilisez <code>::part(name)</code> pour styler ces éléments depuis l'extérieur.
            </p>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Part</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {component.cssParts.map((part) => (
                            <tr>
                                <td><code>{part.name}</code></td>
                                <td>{part.description ?? ''}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    )}

    {/* ── CSS Custom Properties ── */}
    {component.cssProperties && component.cssProperties.length > 0 && (
        <section>
            <h4 id="api-css-props" class="doc-section-title">CSS Custom Properties</h4>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Propriété</th>
                            <th>Défaut</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {component.cssProperties.map((prop) => (
                            <tr>
                                <td><code>{prop.name}</code></td>
                                <td>
                                    {isColorValue(prop.default) && (
                                        <span
                                            class="swatch"
                                            style={`background: ${prop.default}`}
                                            title={prop.default}
                                        />
                                    )}
                                    <code>{prop.default ?? '—'}</code>
                                </td>
                                <td>{prop.description ?? ''}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    )}

    {/* ── Slots ── */}
    {component.slots && component.slots.length > 0 && (
        <section>
            <h4 id="api-slots" class="doc-section-title">Slots</h4>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Slot</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        {component.slots.map((slot) => (
                            <tr>
                                <td><code>{slot.name || '(default)'}</code></td>
                                <td>{slot.description ?? ''}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </section>
    )}
</div>

<style>
    @import '../styles/doc-table.css';

    .component-api {
        display:        flex;
        flex-direction: column;
        gap:            2.5rem;
        margin-top:     2rem;
    }

    .hint {
        font-size:     0.875rem;
        color:         var(--doc-text-muted, #6b7280);
        margin-bottom: 0.75rem;
    }
</style>
