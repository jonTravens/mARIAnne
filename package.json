{
  "name": "@ariane-ui/root",
  "private": true,
  "type": "module",
  "description": "Composants web accessibles pour tous les frameworks.",
  "homepage": "https://ariane-ui.com",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "config": {
    "displayName": "Ariane",
    "tagline": "Composants web accessibles pour tous les frameworks.",
    "url": "https://ariane-ui.com"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,css,astro,md}\" --ignore-path .gitignore",
    "create": "node packages/core/scripts/create-component.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jogo-labs/ariane"
  },
  "packageManager": "npm@10.9.4",
  "overrides": {
    "lit": "^3.0.0"
  }
}
