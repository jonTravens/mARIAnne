---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';

const tocEntries = [
    { id: 'cdn',       label: 'Via CDN',   level: 1 as const },
    { id: 'npm',       label: 'Via npm',   level: 1 as const },
    { id: 'prerequis', label: 'Prérequis', level: 1 as const },
];

const codeCdn = `<!-- Composants (autoloader : ne charge que ce qui est utilisé) -->
<script type="module" src="https://unpkg.com/@marianne/core/cdn/index.js"></scr` + `ipt>

<!-- Thème par défaut -->
<link rel="stylesheet" href="https://unpkg.com/@marianne/core/themes/default.css" />`;

const codeCdnUsage = `<mr-button variant="filled">Valider</mr-button>
<mr-alert variant="success">Opération réussie</mr-alert>`;

const codeNpmInstall = `npm install @marianne/core`;

const codeNpmGlobal = `import '@marianne/core';
import '@marianne/core/themes/default.css';`;

const codeNpmIndividuel = `import '@marianne/core/dist/components/button/button.js';
import '@marianne/core/dist/components/alert/alert.js';
import '@marianne/core/themes/default.css';`;

const codeAutoloader = `<script type="module" src="https://unpkg.com/@marianne/core/cdn/autoloader.js"></scr` + `ipt>`;
---

<Layout
    title="Installation"
    currentPath="/getting-started/installation"
    showToc={true}
>
    <h2>Installation</h2>

    <section class="gs-section" id="cdn">
        <h3>Via CDN <span class="badge">Sans bundler</span></h3>
        <p>
            La méthode la plus rapide. Ajoutez les deux balises dans votre <code>&lt;head&gt;</code> —
            les composants s'enregistrent automatiquement.
        </p>
        <pre><code class="language-html" set:text={codeCdn} /></pre>
        <p>Les composants sont ensuite utilisables directement dans votre HTML :</p>
        <pre><code class="language-html" set:text={codeCdnUsage} /></pre>
    </section>

    <section class="gs-section" id="npm">
        <h3>Via npm <span class="badge">Avec bundler</span></h3>
        <p>Pour une intégration dans un projet avec bundler (Vite, Webpack, Rollup…).</p>
        <pre><code class="language-bash" set:text={codeNpmInstall} /></pre>

        <h4>Import global</h4>
        <p>Enregistre tous les composants en une seule ligne :</p>
        <pre><code class="language-typescript" set:text={codeNpmGlobal} /></pre>

        <h4>Import individuel <span class="badge badge-subtle">Tree-shaking</span></h4>
        <p>Pour inclure uniquement les composants effectivement utilisés :</p>
        <pre><code class="language-typescript" set:text={codeNpmIndividuel} /></pre>

        <h4>Autoloader CDN</h4>
        <p>
            Le bundle CDN inclut un autoloader qui ne charge chaque composant que quand il est utilisé
            dans la page :
        </p>
        <pre><code class="language-html" set:text={codeAutoloader} /></pre>
    </section>

    <section class="gs-section" id="prerequis">
        <h3>Prérequis</h3>
        <ul>
            <li>Node ≥ 20</li>
            <li>npm ≥ 10</li>
            <li>
                Un navigateur supportant les
                <a href="https://developer.mozilla.org/en-US/docs/Web/API/Web_components" target="_blank" rel="noopener">
                    Web Components
                </a>
                (tous les navigateurs modernes)
            </li>
        </ul>
    </section>

    <TableOfContents entries={tocEntries} slot="toc" />
</Layout>

<style>
    h2 {
        color:       var(--doc-text, #111827);
        font-size: 2em;
        margin: 0;

        + p, + section {
            margin-top: 1.5rem;
        }
    }

    .page-title {
    }

    .gs-section {
        margin: 2.5rem 0;
    }

    h3 {
        font-size:      1.1rem;
        font-weight:    700;
        border-bottom:  2px solid var(--doc-border, #e5e7eb);
        padding-bottom: 0.5rem;
        margin-bottom:  1rem;
        color:          var(--doc-text, #111827);
        display:        flex;
        align-items:    center;
        gap:            0.5rem;
    }

    h4 {
        font-size:   0.95rem;
        font-weight: 600;
        color:       var(--doc-text, #111827);
        margin:      1.25rem 0 0.4rem;
        display:     flex;
        align-items: center;
        gap:         0.5rem;
    }

    p {
        font-size:     0.95rem;
        color:         var(--doc-text, #374151);
        margin-bottom: 0.75rem;
        line-height:   1.65;
    }

    ul {
        font-size:    0.95rem;
        color:        var(--doc-text, #374151);
        padding-left: 1.25rem;
        line-height:  1.8;
    }

    a {
        color:           var(--mr-color-primary-500, #2563eb);
        text-decoration: none;
    }

    a:hover { text-decoration: underline; }

    pre {
        background:    #0d1117;
        border-radius: 0.5rem;
        padding:       1rem 1.25rem;
        overflow-x:    auto;
        margin:        0.5rem 0 1rem;
    }

    pre code {
        font-family: 'Fira Code', 'Cascadia Code', monospace;
        font-size:   0.82rem;
        line-height: 1.6;
        color:       #e6edf3;
        background:  transparent;
        padding:     0;
    }

    :global(p code) {
        font-size:     0.85em;
        background:    var(--doc-nav-bg, #f3f4f6);
        color:         var(--doc-text, #111827);
        padding:       0.1em 0.35em;
        border-radius: 0.25em;
    }

    .badge {
        font-size:      0.7rem;
        font-weight:    600;
        padding:        0.15em 0.5em;
        border-radius:  0.25rem;
        background:     color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 12%, transparent);
        color:          var(--mr-color-primary-500, #2563eb);
        letter-spacing: 0.02em;
    }

    .badge-subtle {
        background: color-mix(in srgb, var(--doc-border, #e5e7eb) 80%, transparent);
        color:      var(--doc-text-muted, #6b7280);
    }
</style>
