---
interface Props {
    title: string;
    description?: string;
}

const { title, description = 'Accessible web components library' } = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title} — mARIAnne lib</title>

        <!-- Thème par défaut de la librairie -->
        <link rel="stylesheet" href="/themes/default.css" />

        <style>
            *, *::before, *::after { box-sizing: border-box; }

            body {
                margin: 0;
                font-family: system-ui, -apple-system, sans-serif;
                display: grid;
                grid-template-columns: 260px 1fr;
                min-height: 100vh;
            }

            nav {
                padding: 2rem 1rem;
                border-right: 1px solid #e5e7eb;
                background: #f9fafb;
            }

            nav h2 {
                font-size: 0.75rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #6b7280;
                margin: 1.5rem 0 0.5rem;
            }

            nav a {
                display: block;
                padding: 0.35rem 0.75rem;
                color: #374151;
                text-decoration: none;
                border-radius: 0.375rem;
                font-size: 0.9rem;
            }

            nav a:hover,
            nav a[aria-current="page"] {
                background: #e5e7eb;
                color: #111827;
            }

            main {
                padding: 3rem;
                max-width: 800px;
            }
        </style>
    </head>
    <body>
        <nav>
            <a href="/" style="font-weight: 700; font-size: 1.1rem; display:block; margin-bottom:1.5rem;">
                mARIAnne
            </a>
            <h2>Composants</h2>
            <slot name="nav"></slot>
        </nav>
        <main>
            <slot></slot>
        </main>
    </body>
</html>
