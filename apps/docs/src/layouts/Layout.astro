---
import SiteNav from '../components/SiteNav.astro';

interface Props {
    title: string;
    description?: string;
    currentPath?: string;
    showNav?: boolean;
    showToc?: boolean;
}

const {
    title,
    description = 'Accessible web components library',
    currentPath,
    showNav = true,
    showToc = false,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title} — mARIAnne</title>

        <!-- Thème par défaut de la librairie -->
        <link rel="stylesheet" href="/themes/default.css" />

        <!-- Composants web du DS (nécessaires pour les demos) -->
        <script type="module" src="/cdn/index.js"></script>

        <style>
            *, *::before, *::after { box-sizing: border-box; }

            body {
                margin: 0;
                font-family: system-ui, -apple-system, sans-serif;
                min-height: 100vh;
            }

            body.with-nav {
                display: grid;
                grid-template-columns: 260px 1fr;
            }

            body.with-nav.with-toc {
                grid-template-columns: 260px 1fr 220px;
            }

            main {
                padding: 3rem;
                width: 80%;
                max-width: 1000px;
                margin: 0 auto;
            }

            body:not(.with-nav) main {
                max-width: 90%;
                margin: 0 auto;
            }

            .toc-column {
                padding: 3rem 1rem 3rem 0;
            }

        </style>
    </head>
    <body class={[showNav ? 'with-nav' : '', showToc ? 'with-toc' : ''].filter(Boolean).join(' ')}>
        {showNav && <SiteNav currentPath={currentPath} />}
        <main>
            <slot />
        </main>
        {showToc && (
            <aside class="toc-column">
                <slot name="toc" />
            </aside>
        )}
    </body>
</html>
