---
import SiteNav from '../components/SiteNav.astro';

interface Props {
    title: string;
    description?: string;
    currentPath?: string;
    showNav?: boolean;
    showToc?: boolean;
}

const {
    title,
    description = 'Accessible web components library',
    currentPath,
    showNav = true,
    showToc = false,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title} — mARIAnne</title>

        <!-- Évite le flash de thème au chargement -->
        <script is:inline>
            (function () {
                var stored = localStorage.getItem('marianne-theme') || 'system';
                var theme = stored === 'system'
                    ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                    : stored;
                document.documentElement.setAttribute('data-theme', theme);
                document.documentElement.dataset.themeMode = stored;
            })();
        </script>

        <!-- Thème par défaut de la librairie -->
        <link rel="stylesheet" href="/themes/default.css" />

        <!-- Composants web du DS (nécessaires pour les demos) -->
        <script type="module" src="/cdn/index.js"></script>

        <style>
            *, *::before, *::after { box-sizing: border-box; }

            :root {
                --doc-bg:         #ffffff;
                --doc-text:       #111827;
                --doc-text-muted: #6b7280;
                --doc-nav-bg:     #f8f9fb;
                --doc-nav-border: #e2e4e9;
                --doc-border:     #e5e7eb;
                --doc-header-bg:  color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 4%, #ffffff);
                --doc-header-h:   3.25rem;
            }

            [data-theme="dark"] {
                --doc-bg:         #0f1117;
                --doc-text:       #e6edf3;
                --doc-text-muted: #8b949e;
                --doc-nav-bg:     #161b22;
                --doc-nav-border: #21262d;
                --doc-border:     #21262d;
                --doc-header-bg:  color-mix(in srgb, var(--mr-color-primary-500, #2563eb) 8%, #0f1117);
            }

            html {
                /* Le motif de fond est sur html pour ne pas être masqué par body */
                background: var(--doc-bg);
                transition: background 0.2s;
            }

            html, body {
                margin:     0;
                min-height: 100vh;
                color:      var(--doc-text);
                font-family: system-ui, -apple-system, sans-serif;
                transition: color 0.2s;
            }

            body {
                background-image: radial-gradient(circle,var(--mr-color-primary-500, #2563eb) 1px,transparent 2px);
                background-size:  28px 28px;
                background-color: transparent;
            }

            /* Fond opaque entre le motif (body bg-image) et le contenu */
            body::before {
                content:        '';
                position:       fixed;
                inset:          0;
                background:     var(--doc-bg);
                opacity:        0.92;
                pointer-events: none;
                z-index:        0;
            }

            /* Tout le contenu au-dessus du voile */
            .site-header, .nav-overlay, .layout-body {
                position: relative;
                z-index:  1;
            }

            /* ── Header (toujours visible) ──────────────── */

            .site-header {
                display:         flex;
                position:        sticky;
                top:             0;
                z-index:         100;
                height:          var(--doc-header-h);
                background:      var(--doc-header-bg);
                border-bottom:   1px solid var(--doc-nav-border);
                padding:         0 1rem;
                align-items:     center;
                justify-content: space-between;

                h1 {
                    display: flex;
                    margin: -.2rem 0 0;
                }
            }

            .header-left {
                display:     flex;
                align-items: center;
                gap:         0.5rem;
            }

            .header-brand {
                font-weight:     800;
                font-size:       1.5rem;
                letter-spacing:  -0.02em;
                color:           var(--doc-text);
                text-decoration: none;
            }

            .header-brand .brand-accent {
                color: var(--mr-color-primary-500, #2563eb);
            }

            .header-actions {
                display:     flex;
                align-items: center;
                gap:         0.5rem;
            }

            .icon-btn {
                display:         flex;
                align-items:     center;
                justify-content: center;
                width:           2.25rem;
                height:          2.25rem;
                background:      transparent;
                border:          1px solid var(--doc-border);
                border-radius:   0.4rem;
                cursor:          pointer;
                color:           var(--doc-text-muted);
                transition:      background 0.15s, color 0.15s;
                text-decoration: none;
            }

            .icon-btn:hover {
                background: var(--doc-nav-bg);
                color:      var(--doc-text);
            }

            /* ── Sélecteur thème dropdown ────────────────── */

            #theme-select {
                padding:       0.3rem 0.5rem;
                background:    var(--doc-header-bg);
                color:         var(--doc-text-muted);
                border:        1px solid var(--doc-border);
                border-radius: 0.4rem;
                font-size:     0.8rem;
                cursor:        pointer;
                height:        2.25rem;
                transition:    background 0.15s, color 0.15s;
            }

            #theme-select:hover {
                background: var(--doc-nav-bg);
                color:      var(--doc-text);
            }

            /* ── Overlay drawer ─────────────────────────── */

            .nav-overlay {
                display:        none;
                position:       fixed;
                inset:          0;
                background:     rgba(0, 0, 0, 0.4);
                z-index:        200;
                opacity:        0;
                pointer-events: none;
                transition:     opacity 0.2s;
            }

            .nav-overlay.open {
                pointer-events: auto;
            }

            /* ── Layout body ────────────────────────────── */

            .layout-body {
                height: calc(100vh - var(--doc-header-h));
            }

            .layout-body.with-nav {
                display:               grid;
                grid-template-columns: 260px 1fr;
            }

            .nav-column {
                height:     100%;
                overflow-y: auto;
                display:    flex;
                flex-direction: column;
                flex-grow:  1;
            }

            main {
                padding:    0;
                height:     100%;
                overflow-y: auto;
            }

            /* Contenu centré dans main */
            .main-inner {
                padding:   4rem 3rem;
                max-width: 1100px;
                margin:    0 auto;
            }

            /* Avec TOC fixe à droite : on réserve de la place côté droit */
            .layout-body.with-toc .main-inner {
                padding-right: 260px;
            }

            .layout-body:not(.with-nav) main {
                width: 100%;
            }

            .layout-body:not(.with-nav) .main-inner {
                max-width: 100%;
                padding:   0;
            }

            /* Aside TOC — position fixe à droite, indépendante du flux */
            .toc-column {
                position:   fixed;
                top:        var(--doc-header-h);
                right:      0;
                width:      220px;
                height:     calc(100vh - var(--doc-header-h));
                padding:    3rem 1rem 3rem 0;
                overflow-y: auto;
            }

            /* ── Responsive ─────────────────────────────── */

            /* Sur desktop : burger masqué, nav-overlay masqué */
            #burger-btn   { display: none; }
            .nav-overlay  { display: none; }

            @media (max-width: 768px) {
                #burger-btn  { display: flex; }
                .nav-overlay { display: block; }

                .layout-body.with-nav {
                    display: block;
                }

                .nav-column {
                    position:   fixed;
                    top:        0;
                    left:       0;
                    height:     100vh;
                    width:      280px;
                    z-index:    300;
                    transform:  translateX(-100%);
                    transition: transform 0.25s ease;
                }

                .nav-column.open  { transform: translateX(0); }
                .nav-overlay.open { opacity: 1; }

                .layout-body {
                    height:     auto;
                    min-height: calc(100vh - var(--doc-header-h));
                    overflow-y: visible;
                }

                main {
                    width:      100%;
                    height:     auto;
                    overflow-y: visible;
                }

                .main-inner,
                .layout-body.with-toc .main-inner {
                    padding:   1.5rem 1rem;
                    max-width: 100%;
                }

                .toc-column { display: none; }
            }
        </style>
    </head>
    <body>
        <!-- Header permanent (desktop + mobile) -->
        <header class="site-header">
            <div class="header-left">
                <!-- Burger : visible uniquement en mobile via CSS -->
                <button class="icon-btn" id="burger-btn" aria-label="Ouvrir la navigation" aria-expanded="false" aria-controls="site-nav-column">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>
                <h1>
                    <a href="/" class="header-brand">
                        m<span class="brand-accent">ARIA</span>nne
                    </a>
                </h1>
            </div>
            <div class="header-actions">
                <!-- Sélecteur thème dropdown -->
                <select id="theme-select" aria-label="Thème d'affichage">
                    <option value="light">☀ Clair</option>
                    <option value="system">⬛ Auto</option>
                    <option value="dark">☾ Sombre</option>
                </select>
                <!-- Lien GitHub -->
                <a
                    href="https://github.com/jonTravens/mARIAnne"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon-btn header-github"
                    aria-label="Code source sur GitHub"
                >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.79 23.4c.6.1.82-.26.82-.57v-2.2c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.08-.74.08-.73.08-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.48 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57A12 12 0 0 0 12 .3"/></svg>
                </a>
            </div>
        </header>

        <div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

        <div class={['layout-body', showNav ? 'with-nav' : '', showToc ? 'with-toc' : ''].filter(Boolean).join(' ')}>
            {showNav && (
                <div class="nav-column" id="site-nav-column">
                    <SiteNav currentPath={currentPath} />
                </div>
            )}
            <main>
                <div class="main-inner">
                    <slot />
                </div>
            </main>
            {showToc && (
                <aside class="toc-column">
                    <slot name="toc" />
                </aside>
            )}
        </div>

        <script>
            // ── Thème (Light / Auto / Dark) ────────────────────────────────────────

            function resolveTheme(mode: string): 'light' | 'dark' {
                if (mode === 'dark')  return 'dark';
                if (mode === 'light') return 'light';
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }

            function applyMode(mode: string) {
                const theme = resolveTheme(mode);
                document.documentElement.setAttribute('data-theme', theme);
                document.documentElement.dataset.themeMode = mode;

                // Mettre à jour la valeur du select
                const select = document.getElementById('theme-select') as HTMLSelectElement | null;
                if (select) select.value = mode;
            }

            // Lire le mode sauvegardé (défaut : 'system')
            const savedMode = localStorage.getItem('marianne-theme') || 'system';
            applyMode(savedMode);

            // Écouter les changements du select
            const themeSelect = document.getElementById('theme-select') as HTMLSelectElement | null;
            themeSelect?.addEventListener('change', () => {
                const mode = themeSelect.value || 'system';
                localStorage.setItem('marianne-theme', mode);
                applyMode(mode);
            });

            // Réagir aux changements de préférence système quand le mode est 'system'
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if ((localStorage.getItem('marianne-theme') || 'system') === 'system') {
                    applyMode('system');
                }
            });

            // ── Nav burger ─────────────────────────────────────────────────────────

            const burgerBtn  = document.getElementById('burger-btn');
            const navOverlay = document.getElementById('nav-overlay');
            const navColumn  = document.getElementById('site-nav-column');

            function openNav() {
                navColumn?.classList.add('open');
                navOverlay?.classList.add('open');
                burgerBtn?.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            }

            function closeNav() {
                navColumn?.classList.remove('open');
                navOverlay?.classList.remove('open');
                burgerBtn?.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }

            burgerBtn?.addEventListener('click', openNav);
            navOverlay?.addEventListener('click', closeNav);
            navColumn?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav));
        </script>
    </body>
</html>
