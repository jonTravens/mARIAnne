---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Playground from '../../components/Playground.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import manifest from '@cem';
import { getSlug } from '../../utils/tag-name.ts';

// ─── Types ────────────────────────────────────────────────────────────────────

interface CemMember {
    kind:        string;
    name:        string;
    attribute?:  string;
    privacy?:    string;
    static?:     boolean;
    readonly?:   boolean;
    type?:       { text: string };
    default?:    string;
    description?: string;
}

interface CemDeclaration {
    kind:           string;
    customElement?: boolean;
    tagName?:       string;
    name:           string;
    summary?:       string;
    description?:   string;
    members?:       CemMember[];
    attributes?:    unknown[];
    events?:        unknown[];
    cssParts?:      unknown[];
    cssProperties?: unknown[];
    slots?:         unknown[];
    'x-display'?:   'demo' | 'docs';
    'x-parent'?:    string;
}

type MdxEntry = Awaited<ReturnType<typeof getCollection<'components'>>>[number];

// ─── Détection du type de contrôle depuis le type CEM ─────────────────────────

function isStringUnion(typeText: string): boolean {
    const clean = typeText.replace(/\s*\|\s*(undefined|null)/g, '').trim();
    const parts = clean.split(/\s*\|\s*/);
    return parts.length > 1 && parts.every((p) => /^['"][^'"]+['"]$/.test(p));
}

function getOptions(typeText: string): string[] {
    return typeText
        .replace(/\s*\|\s*(undefined|null)/g, '')
        .split(/\s*\|\s*/)
        .map((p) => p.replace(/^['"]|['"]$/g, ''));
}

function hasUndefined(typeText: string): boolean {
    return /\bundefined\b/.test(typeText);
}

// ─── Routes statiques ─────────────────────────────────────────────────────────

export async function getStaticPaths() {
    const components: CemDeclaration[] = manifest.modules
        .flatMap((m: { declarations?: CemDeclaration[] }) => m.declarations ?? [])
        .filter((d: CemDeclaration) => d.kind === 'class' && d.customElement === true);

    const mdxEntries = await getCollection('components');
    const mdxByTag   = Object.fromEntries(mdxEntries.map((e) => [e.data.tagName, e]));

    return components.map((component) => ({
        params: { slug: getSlug(component.tagName!) },
        props:  { component, mdx: mdxByTag[component.tagName!] ?? null },
    }));
}

// ─── Props de la page ─────────────────────────────────────────────────────────

const { component, mdx } = Astro.props as {
    component: CemDeclaration;
    mdx: MdxEntry | null;
};

const { Content } = mdx ? await mdx.render() : { Content: null };

const variants    = mdx?.data.variants ?? [];
const pageTitle   = mdx?.data.title ?? component.name;
const pageDesc    = mdx?.data.description ?? component.summary;
const displayMode = component['x-display'] ?? 'demo';
const parentTag   = component['x-parent'];

// ─── HTML initial du playground ───────────────────────────────────────────────

const playgroundVariantName = mdx?.data.playgroundTemplate;
const playgroundVariant = playgroundVariantName
    ? variants.find((v: { name: string }) => v.name === playgroundVariantName)
    : variants[0];
const playgroundHtml = playgroundVariant?.html ?? '';

// ─── Contrôles du playground ──────────────────────────────────────────────────

const controls = (component.members ?? [])
    .filter(
        (m) =>
            m.kind === 'field' &&
            m.privacy !== 'private' &&
            m.privacy !== 'protected' &&
            m.attribute &&
            !m.readonly,
    )
    .map((m) => {
        const typeText    = m.type?.text ?? '';
        const stringUnion = isStringUnion(typeText);
        return {
            attribute:    m.attribute!,
            description:  m.description,
            default:      m.default,
            controlType:  stringUnion
                ? ('select' as const)
                : typeText === 'boolean'
                    ? ('checkbox' as const)
                    : typeText === 'number' || typeText === 'number | undefined'
                        ? ('number' as const)
                        : ('text' as const),
            options:      stringUnion ? getOptions(typeText) : [],
            addDefault:   stringUnion && hasUndefined(typeText),
        };
    });

// ─── TOC ──────────────────────────────────────────────────────────────────────

const tocEntries = [
    ...(variants.length > 0
        ? [
            { id: 'exemples', label: 'Exemples', level: 1 as const },
            ...variants.map((v: { name: string; label?: string }) => ({
                id:    `exemple-${v.name}`,
                label: v.label ?? v.name,
                level: 2 as const,
            })),
          ]
        : []),
    ...(displayMode === 'demo'
        ? [{ id: 'playground', label: 'Playground', level: 1 as const }]
        : []),
    { id: 'reference-api', label: 'Référence API', level: 1 as const },
];
---

<Layout
    title={pageTitle}
    currentPath={'/components/' + getSlug(component.tagName!)}
    showToc={true}
>
    <h1>{pageTitle}</h1>
    <code>&lt;{component.tagName}&gt;</code>
    {pageDesc && <p class="summary">{pageDesc}</p>}

    <Playground
        variants={variants}
        tagName={component.tagName!}
        displayMode={displayMode}
        parentTag={parentTag}
        playgroundHtml={playgroundHtml}
        controls={controls}
        component={component}
    />

    {Content && (
        <section class="narrative">
            <Content />
        </section>
    )}

    <TableOfContents entries={tocEntries} slot="toc" />
</Layout>

<style>
    h1 { margin-bottom: 0.25rem; }

    h1 + code {
        font-size:  1rem;
        background: none;
        padding:    0;
        color:      #6b7280;
    }

    .summary {
        font-size:     1.05rem;
        color:         #4b5563;
        margin-bottom: 0.25rem;
    }

    .narrative {
        margin:      1.5rem 0;
        color:       #374151;
        line-height: 1.7;
    }

    .narrative :global(p)    { margin-bottom: 0.75rem; }

    .narrative :global(code) {
        font-size:     0.85em;
        background:    #f3f4f6;
        padding:       0.1em 0.35em;
        border-radius: 0.25em;
    }
</style>
